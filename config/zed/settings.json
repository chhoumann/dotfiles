// Zed settings
//
// For information on how to configure Zed, see the Zed
// documentation: https://zed.dev/docs/configuring-zed
//
// To see all of Zed's default settings without changing your
// custom settings, run `zed: open default settings` from the
// command palette (cmd-shift-p / ctrl-shift-p)
{
  "edit_predictions": {
    "allow_data_collection": "no"
  },
  "word_diff_enabled": true,
  "diff_view_style": "split",
  "cli_default_open_behavior": "new_window",
  "project_panel": {
    "dock": "left"
  },
  "outline_panel": {
    "dock": "left"
  },
  "collaboration_panel": {
    "dock": "left"
  },
  "git_panel": {
    "dock": "left",
    "tree_view": true,
    "sort_by_path": true,
    "file_icons": true
  },
  "agent_servers": {
    "cline": {
      "type": "registry"
    },
    "codex-acp": {
      "type": "registry",
      "default_mode": "full-access"
    }
  },
  "agent": {
    "tool_permissions": {
      "default": "allow"
    },
    "dock": "right",
    "default_profile": "write",
    "default_model": {
      "effort": "medium",
      "enable_thinking": true,
      "provider": "openai-subscribed",
      "model": "gpt-5.5"
    },
    "use_modifier_to_send": true,
    "play_sound_when_agent_done": "always",
    "model_parameters": []
  },
  "inlay_hints": {
    "enabled": false
  },
  "terminal": {
    "font_family": "CaskaydiaCove Nerd Font Mono"
  },
  "multi_cursor_modifier": "cmd_or_ctrl",
  "vertical_scroll_margin": 10.0,
  "minimap": {
    "show": "auto"
  },
  "cursor_blink": true,
  "autosave": {
    "after_delay": {
      "milliseconds": 1000
    }
  },
  "auto_indent_on_paste": true,
  "linked_edits": true,
  "use_on_type_format": true,
  "show_whitespaces": "none",
  "show_edit_predictions": true,
  "indent_guides": {
    "enabled": false
  },
  "file_types": {
    "html": ["*.tmpl"],
    "markdown": ["*.mdx"]
  },
  "vim_mode": true,
  "base_keymap": "VSCode",
  "ui_font_size": 16,
  "buffer_font_size": 15,
  "theme": {
    "mode": "system",
    "light": "One Light",
    "dark": "Cursor Dark"
  },
  "languages": {
    "Python": {
      "indent_guides": {
        "background_coloring": "disabled",
        "enabled": true
      },
      "language_servers": ["ty", "!basedpyright"]
    }
  },
  "lsp": {
    "clangd": {
      "binary": {
        "path": "/usr/bin/clangd",
        "arguments": ["--std=c++23"]
      }
    }
  }
}
