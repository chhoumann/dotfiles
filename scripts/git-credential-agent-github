#!/usr/bin/env bash
# Git credential protocol adapter for GitHub App installation tokens. On a
# regular workstation it delegates to gh's existing keyring authentication.
set -euo pipefail

operation="${1:-get}"
request="$(</dev/stdin)"
host="$(printf '%s\n' "$request" | sed -n 's/^host=//p' | head -n 1)"
token_file="${OP_SERVICE_ACCOUNT_TOKEN_FILE:-$HOME/.config/agent-auth/op-service-account-token}"

if [[ "$operation" == "get" && "$host" == "github.com" && -r "$token_file" ]]; then
  printf 'username=x-access-token\npassword=%s\n\n' "$("$HOME/.local/bin/github-app-token")"
  exit 0
fi

gh_bin=""
for candidate in "$HOME/.local/bin/gh" /opt/homebrew/bin/gh /usr/bin/gh /usr/local/bin/gh; do
  if [[ -x "$candidate" ]]; then
    gh_bin="$candidate"
    break
  fi
done

if [[ -z "$gh_bin" ]]; then
  echo "GitHub CLI is not installed" >&2
  exit 127
fi

printf '%s\n' "$request" | "$gh_bin" auth git-credential "$operation"
